generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int           @id @default(autoincrement())
  email         String?       @unique @db.VarChar(255)
  phoneNumber   String?       @unique @map("phone_number") @db.VarChar(20)
  walletAddress String?       @unique @map("wallet_address") @db.VarChar(44)
  ksScore       Float         @default(0.0) @map("ks_score")
  reputationScore Int         @default(0) @map("reputation_score")
  knowUBalance  Int           @default(0) @map("know_u_balance")
  knowGBalance  Float         @default(0.0) @map("know_g_balance")
  accountStatus AccountStatus @default(ACTIVE) @map("account_status")
  role          UserRole      @default(USER)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  security            UserSecurity?
  profile             UserProfile?
  refreshTokens       RefreshToken[]
  articles            Article[]
  suggestions         Suggestion[]        @relation("SuggestionAuthor")
  comments            Comment[]
  interactions        Interaction[]
  notifications       Notification[]
  collections         Collection[]
  walletTransactions  WalletTransaction[]
  followers           Follow[]            @relation("FollowTarget")
  following           Follow[]            @relation("FollowSource")
  badges              UserBadge[]
  editedArticleVersions ArticleVersion[]  @relation("ArticleVersionEditor")

  @@index([ksScore(sort: Desc)], map: "idx_users_ks_score")
  @@index([accountStatus], map: "idx_users_account_status")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

model UserSecurity {
  id                         Int       @id @default(autoincrement())
  userId                     Int       @unique @map("user_id")
  passwordHash               String?   @map("password_hash") @db.VarChar(255)
  isEmailVerified            Boolean   @default(false) @map("is_email_verified")
  isPhoneVerified            Boolean   @default(false) @map("is_phone_verified")
  lastLoginAt                DateTime? @map("last_login_at")
  loginAttempts              Int       @default(0) @map("login_attempts")
  lockedUntil                DateTime? @map("locked_until")
  emailOtp                   String?   @map("email_otp") @db.VarChar(255)
  emailOtpAttempts           Int       @default(0) @map("email_otp_attempts")
  emailOtpLastSentAt         DateTime? @map("email_otp_last_sent_at")
  emailOtpLockedUntil        DateTime? @map("email_otp_locked_until")
  passwordResetToken         String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetExpiresAt     DateTime? @map("password_reset_expires_at")
  emailVerificationToken     String?   @map("email_verification_token") @db.VarChar(255)
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security")
}

model UserProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique @map("user_id")
  displayName        String   @map("display_name") @db.VarChar(100)
  avatarUrl          String?  @map("avatar_url") @db.VarChar(500)
  bio                String?  @db.Text
  isProfilePublic    Boolean  @default(true) @map("is_profile_public")
  firstName          String?  @map("first_name") @db.VarChar(50)
  lastName           String?  @map("last_name") @db.VarChar(50)
  language           String   @default("vi") @db.VarChar(5)
  timezone           String   @default("Asia/Ho_Chi_Minh") @db.VarChar(50)
  emailNotifications Boolean  @default(true) @map("email_notifications")
  pushNotifications  Boolean  @default(true) @map("push_notifications")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([displayName], map: "idx_user_profiles_display_name")
  @@index([isProfilePublic], map: "idx_user_profiles_is_public")
  @@map("user_profiles")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  revoked    Boolean   @default(false)
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  userAgent  String?   @map("user_agent") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  replacedBy String?   @map("replaced_by") @db.VarChar(255)
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([revoked], map: "idx_refresh_tokens_revoked")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

model Context {
  id              Int         @id @default(autoincrement())
  type            ContextType
  name            String      @db.VarChar(255)
  latitude        Float?
  longitude       Float?
  category        String?     @db.VarChar(100)
  avgRating       Float       @default(0.0) @map("avg_rating")
  source          String?     @db.VarChar(64)
  sourceRef       String?     @map("source_ref") @db.VarChar(128)
  description     String?     @db.Text
  address         String?     @db.VarChar(500)
  isReviewed      Boolean     @default(false) @map("is_reviewed")
  reviewCount     Int         @default(0) @map("review_count")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  articles        Article[]
  collectionItems CollectionItem[]

  @@unique([latitude, longitude], map: "uq_contexts_latitude_longitude")
  @@unique([source, sourceRef], map: "uq_contexts_source_source_ref")
  @@index([type], map: "idx_contexts_type")
  @@index([category], map: "idx_contexts_category")
  @@index([isReviewed], map: "idx_contexts_is_reviewed")
  @@index([avgRating(sort: Desc)], map: "idx_contexts_avg_rating")
  @@map("contexts")
}

model Article {
  id            Int           @id @default(autoincrement())
  slug          String        @unique @db.VarChar(255)
  title         String        @db.VarChar(500)
  content       String        @db.Text
  type          ArticleType
  status        ArticleStatus @default(DRAFT)
  tier          ArticleTier   @default(TIER_0)
  rankingScore  Float         @default(0.0) @map("ranking_score")
  kvScore       KVScore       @default(LOW) @map("kv_score")
  contextId     Int           @map("context_id")
  authorId      Int           @map("author_id")
  viewCount     Int           @default(0) @map("view_count")
  saveCount     Int           @default(0) @map("save_count")
  upvoteCount   Int           @default(0) @map("upvote_count")
  isEvergreen   Boolean       @default(false) @map("is_evergreen")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  context           Context           @relation(fields: [contextId], references: [id], onDelete: Restrict)
  author            User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  taxonomies        ArticleTaxonomy[]
  suggestions       Suggestion[]
  comments          Comment[]
  versions          ArticleVersion[]
  interactions      Interaction[]
  collectionItems   CollectionItem[]

  @@index([authorId], map: "idx_articles_author_id")
  @@index([contextId], map: "idx_articles_context_id")
  @@index([status], map: "idx_articles_status")
  @@index([type], map: "idx_articles_type")
  @@index([tier], map: "idx_articles_tier")
  @@index([rankingScore(sort: Desc)], map: "idx_articles_ranking_score")
  @@index([status, tier, rankingScore(sort: Desc)], map: "idx_articles_feed")
  @@index([kvScore], map: "idx_articles_kv_score")
  @@map("articles")
}

model Taxonomy {
  id          Int          @id @default(autoincrement())
  type        TaxonomyType
  name        String       @db.VarChar(100)
  slug        String       @unique @db.VarChar(100)
  parentId    Int?         @map("parent_id")
  description String?      @db.Text

  parent   Taxonomy?         @relation("TaxonomyHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Taxonomy[]        @relation("TaxonomyHierarchy")
  articles ArticleTaxonomy[]

  @@index([type], map: "idx_taxonomies_type")
  @@index([parentId], map: "idx_taxonomies_parent_id")
  @@map("taxonomies")
}

model ArticleTaxonomy {
  articleId   Int      @map("article_id")
  taxonomyId  Int      @map("taxonomy_id")

  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  taxonomy Taxonomy @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)

  @@id([articleId, taxonomyId])
  @@index([taxonomyId], map: "idx_article_taxonomies_taxonomy_id")
  @@map("article_taxonomies")
}

model Suggestion {
  id         Int              @id @default(autoincrement())
  authorId   Int              @map("author_id")
  articleId  Int              @map("article_id")
  content    String           @db.Text
  status     SuggestionStatus @default(PENDING)
  comment    String?          @db.Text
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  author  User    @relation("SuggestionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([authorId], map: "idx_suggestions_author_id")
  @@index([articleId], map: "idx_suggestions_article_id")
  @@index([status], map: "idx_suggestions_status")
  @@map("suggestions")
}

model Comment {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  articleId   Int       @map("article_id")
  parentId    Int?      @map("parent_id")
  content     String    @db.Text
  upvoteCount Int       @default(0) @map("upvote_count")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([articleId, createdAt], map: "idx_comments_article_created_at")
  @@index([userId], map: "idx_comments_user_id")
  @@index([parentId], map: "idx_comments_parent_id")
  @@index([deletedAt], map: "idx_comments_deleted_at")
  @@map("comments")
}

model ArticleVersion {
  id            Int      @id @default(autoincrement())
  articleId     Int      @map("article_id")
  editorId      Int      @map("editor_id")
  versionNumber Int      @map("version_number")
  content       String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editor  User    @relation("ArticleVersionEditor", fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([articleId, versionNumber], map: "uq_article_versions_article_version_number")
  @@index([articleId], map: "idx_article_versions_article_id")
  @@map("article_versions")
}

model Interaction {
  id                 Int             @id @default(autoincrement())
  userId             Int             @map("user_id")
  articleId          Int             @map("article_id")
  type               InteractionType
  timeSpentMs        Int?            @map("time_spent_ms")
  locationLat        Float?          @map("location_lat")
  locationLong       Float?          @map("location_long")
  scrollDepthPercent Int?            @map("scroll_depth_percent")
  createdAt          DateTime        @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, type], map: "idx_interactions_article_type")
  @@index([userId, type], map: "idx_interactions_user_type")
  @@index([userId], map: "idx_interactions_user_id")
  @@index([articleId], map: "idx_interactions_article_id")
  @@index([type], map: "idx_interactions_type")
  @@map("interactions")
}

model Collection {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String   @db.VarChar(255)
  isPublic    Boolean  @default(false) @map("is_public")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId, isPublic], map: "idx_collections_user_public")
  @@index([userId], map: "idx_collections_user_id")
  @@map("collections")
}

model CollectionItem {
  id           Int      @id @default(autoincrement())
  collectionId Int      @map("collection_id")
  articleId    Int      @map("article_id")
  contextId    Int?     @map("context_id")
  addedAt      DateTime @default(now()) @map("added_at")
  order        Int      @default(0)
  notes        String?  @db.Text

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article    Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  context    Context?   @relation(fields: [contextId], references: [id], onDelete: SetNull)

  @@index([collectionId], map: "idx_collection_items_collection_id")
  @@index([articleId], map: "idx_collection_items_article_id")
  @@index([contextId], map: "idx_collection_items_context_id")
  @@map("collection_items")
}

model WalletTransaction {
  id         Int                   @id @default(autoincrement())
  userId     Int                   @map("user_id")
  type       WalletTransactionType
  currency   Currency
  amount     Float
  reasonCode String?               @map("reason_code") @db.VarChar(100)
  refId      Int?                  @map("ref_id")
  metadata   String?               @db.Text
  createdAt  DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, currency], map: "idx_wallet_transactions_user_currency")
  @@index([createdAt], map: "idx_wallet_transactions_created_at")
  @@map("wallet_transactions")
}

model Follow {
  followingId Int      @map("following_id")
  followerId  Int      @map("follower_id")
  createdAt   DateTime @default(now()) @map("created_at")

  following User @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)
  follower  User @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)

  @@id([followingId, followerId])
  @@index([followerId], map: "idx_follows_follower_id")
  @@index([followingId], map: "idx_follows_following_id")
  @@map("follows")
}

model Badge {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  iconUrl     String?  @map("icon_url") @db.VarChar(500)
  criteria    String?  @db.Text

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  badgeId   Int      @map("badge_id")
  userId    Int      @map("user_id")
  awardedAt DateTime @default(now()) @map("awarded_at")

  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([badgeId, userId])
  @@map("user_badges")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(100)
  content   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  refId     Int?     @map("ref_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt], map: "idx_notifications_user_read_created_at")
  @@map("notifications")
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFY
  SUSPENDED
  BANNED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ArticleType {
  POST
  REVIEW
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  FLAGGED
  HIDDEN
}

enum ArticleTier {
  TIER_0
  TIER_1
  TIER_2
  TIER_3
}

enum KVScore {
  LOW
  MEDIUM
  HIGH
}

enum ContextType {
  PLACE
  ENTITY
  TOPIC
}

enum TaxonomyType {
  CATEGORY
  TAG
}

enum InteractionType {
  VIEW
  SHARE
  SAVE
  UPVOTE
  DOWNVOTE
  REPORT
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum WalletTransactionType {
  EARN
  SPEND
  DEPOSIT
  WITHDRAW
}

enum Currency {
  POINTS
  KNOW_U
  KNOW_G
}
